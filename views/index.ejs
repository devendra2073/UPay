<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pay with Upay</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8fafc; }
        .qr-gradient { background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%); }
        .modal-overlay { background: rgba(0, 0, 0, 0.8); backdrop-filter: blur(8px); }
    </style>
</head>
<body class="flex items-center justify-center min-h-screen p-4">

    <div id="payment-card" class="bg-white w-full max-w-md rounded-3xl shadow-2xl overflow-hidden border border-gray-100 relative">
        
        <div class="p-4 text-center border-b border-gray-50">
            <div class="flex justify-between items-center mb-4">
                <span class="text-xs font-bold tracking-widest text-indigo-600 uppercase">Upay Gateway</span>
                <span class="text-xs text-gray-400 uppercase tracking-tighter">ID: #<%=tid%></span>
            </div>
            <div class="relative w-15 h-15 mx-auto mb-3">
                <div class="absolute inset-0 bg-indigo-100 rounded-full animate-pulse opacity-50"></div>
                <div class="relative w-15 h-15 bg-white rounded-full flex items-center justify-center border-4 border-white shadow-md overflow-hidden">
                    <img src="<%=logo%>" alt="<%=company%>" class="w-full h-full object-contain" onerror="this.src='https://ui-avatars.com/api/?name=<%=company%>&background=6366f1&color=fff'" />
                </div>
            </div>
            <h2 class="text-lg font-bold text-gray-800 tracking-tight"><%=company%></h2>
            <p class="text-3xl font-extrabold text-gray-900 mt-2">₹<%=amount.toLocaleString("en-IN",{minimumFractionDigits:2})%></p>
        </div>

        <div class="p-4 text-center">
            <p class="text-sm font-medium text-gray-500 mb-3">Scan QR or select an app to pay</p>
            <div class="qr-gradient p-1 inline-block rounded-2xl shadow-lg mb-2">
                <div class="bg-white p-3 rounded-xl">
                    <img id="qr-image" src="<%=obj%>" alt="UPI QR Code" class="w-35 h-35" crossorigin="anonymous">
                </div>
            </div>
            
            <button onclick="downloadQR()" class="flex items-center justify-center mx-auto mb-6 text-[10px] font-bold text-indigo-500 hover:text-indigo-700 uppercase tracking-widest transition-all active:scale-95">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                Save QR to Gallery
            </button>

            <div class="space-y-3 text-left">
                <p class="text-xs font-bold text-gray-400 uppercase tracking-widest text-center mb-4">Select UPI App</p>
                <div class="grid grid-cols-2 gap-3">
                    <a href="<%=intent%>" class="flex items-center p-3 border border-gray-100 rounded-xl hover:bg-gray-50 transition active:scale-95">
                        <img src="/assets/gpay.png" class="w-6 h-6 mr-3" alt="GPay">
                        <span class="text-sm font-medium">GPay</span>
                    </a>
                    <a href="<%=intent%>" class="flex items-center p-3 border border-gray-100 rounded-xl hover:bg-gray-50 transition active:scale-95">
                        <img src="/assets/phonepe.jpeg" class="w-6 h-6 mr-3" alt="PhonePe">
                        <span class="text-sm font-medium">PhonePe</span>
                    </a>
                    <a href="<%=intent%>" class="flex items-center p-3 border border-gray-100 rounded-xl hover:bg-gray-50 transition active:scale-95">
                        <img src="/assets/paytm.png" class="w-6 h-6 mr-3" alt="Paytm">
                        <span class="text-sm font-medium">Paytm</span>
                    </a>
                    <a href="<%=intent%>" class="flex items-center p-3 border border-gray-100 rounded-xl hover:bg-gray-50 transition active:scale-95">
                        <img src="/assets/bhim.png" class="w-6 h-6 mr-3" alt="BHIM">
                        <span class="text-sm font-medium">BHIM</span>
                    </a>
                </div>
            </div>
        </div>

        <div class="bg-gray-50 p-4 flex justify-between items-center text-[10px] font-bold text-gray-400 uppercase tracking-widest">
            <div class="flex items-center">
                <span class="w-2 h-2 bg-green-500 rounded-full mr-2 animate-pulse"></span>
                Secure Transaction
            </div>
            <div class="flex items-center text-red-500">
                <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                Expires in <span id="timer" class="ml-1">05:00</span>
            </div>
        </div>

        <div id="popup-overlay" class="hidden absolute inset-0 modal-overlay z-50 flex items-center justify-center p-6">
            <div id="success-popup" class="hidden bg-white rounded-3xl p-8 text-center w-full shadow-2xl">
                <div class="w-20 h-20 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                </div>
                <h3 class="text-xl font-bold text-gray-800">Payment Success!</h3>
                <p class="text-gray-500 text-sm mt-2">Transfer verified. Redirecting...</p>
                <p class="text-gray-300 text-sm mt-2"><b>UTR:</b> <span id="utr"></span></p>
            </div>
            <div id="timeout-popup" class="hidden bg-white rounded-3xl p-8 text-center w-full shadow-2xl">
                <div class="w-20 h-20 bg-red-100 text-red-600 rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
                </div>
                <h3 class="text-xl font-bold text-gray-800">Time's Up!</h3>
                <p class="text-gray-500 text-sm mt-2">For your security, this session has expired.</p>
                <button onclick="location.reload()" class="mt-6 w-full py-3 bg-indigo-600 text-white rounded-xl font-bold hover:bg-indigo-700">Refresh Page</button>
            </div>
        </div>
    </div>
    <script>
        let interval;
        let timeInSeconds = 300; 
        const timerElement = document.getElementById('timer');
        const overlay = document.getElementById('popup-overlay');
        const timeoutPopup = document.getElementById('timeout-popup');
        const successPopup = document.getElementById('success-popup');

        // Timer Logic
        const countdown = setInterval(() => {
            const minutes = Math.floor(timeInSeconds / 60);
            const seconds = timeInSeconds % 60;
            timerElement.innerText = `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;

            if (timeInSeconds <= 0) {
                clearInterval(countdown);
                showPopup('timeout');
            }
            timeInSeconds--;
        }, 1000);

        function showPopup(type) {
            overlay.classList.remove('hidden');
            if (type === 'timeout') timeoutPopup.classList.remove('hidden');
            if (type === 'success') successPopup.classList.remove('hidden');
        }

        // New Download Functionality
        async function downloadQR() {
            const img = document.getElementById('qr-image');
            try {
                // We draw to a canvas to ensure the file is named correctly upon download
                const canvas = document.createElement('canvas');
                const ctx = canvas.getContext('2d');
                canvas.width = img.naturalWidth || 500;
                canvas.height = img.naturalHeight || 500;
                ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
                
                const link = document.createElement('a');
                link.href = canvas.toDataURL('image/png');
                link.download = `Upay_QR_${Date.now()}.png`;
                link.click();
            } catch (err) {
                // Fallback for strict CORS
                const link = document.createElement('a');
                link.href = img.src;
                link.download = 'payment_qr.png';
                link.click();
            }
        }

        // Status Polling
        const getStatus = async () => {
            try {
                const response = await fetch("/pay/status/<%=tid%>");
                const data = await response.json();
                if (data.status) {
                    showPopup("success");
                    document.getElementById("utr").innerText = data.utr;
                    clearInterval(interval);
                    clearInterval(countdown);
                    setTimeout(() => { location.href = "<%=redirect%>" }, 4000);
                }
            } catch (e) { console.error("Status check failed", e); }
        };

        interval = setInterval(getStatus, 2000);
    </script>
</body>
</html>
