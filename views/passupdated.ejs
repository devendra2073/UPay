<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UPay | Success</title>
    
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    
    <script src="https://unpkg.com/lucide@latest"></script>

    <style type="text/tailwindcss">
        @theme {
            --color-upay-green: #22c55e;
        }

        body {
            background-color: #f8fafc;
            background-image: 
                radial-gradient(at 50% 0%, rgba(34, 197, 94, 0.05) 0px, transparent 50%);
        }

        .success-checkmark {
            animation: scaleIn 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @keyframes scaleIn {
            0% { transform: scale(0); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }
    </style>
</head>
<body class="flex items-center justify-center min-h-screen p-4 font-sans text-slate-900">

    <div class="w-full max-w-md bg-white rounded-3xl shadow-xl shadow-slate-200/60 border border-slate-100 overflow-hidden text-center">
        
        <div class="h-2 bg-green-500"></div>

        <div class="p-10">
            <div class="flex flex-col items-center mb-6">
                <div class="success-checkmark w-20 h-20 bg-green-50 rounded-full flex items-center justify-center mb-6 border border-green-100 shadow-inner">
                    <i data-lucide="check-circle-2" class="text-green-500 w-10 h-10"></i>
                </div>
                <h1 class="text-2xl font-bold tracking-tight text-slate-900">Password Updated!</h1>
                <p class="text-slate-500 text-sm mt-3 leading-relaxed">
                    Your account security credentials have been successfully reset. You can now log in to **UPay** with your new password.
                </p>
            </div>

            <div class="bg-green-50/50 rounded-2xl p-5 mb-8 border border-green-100/50 flex items-center gap-4 text-left">
                <div class="bg-white p-2 rounded-lg shadow-sm border border-green-100">
                    <i data-lucide="shield-check" class="w-5 h-5 text-green-600"></i>
                </div>
                <div>
                    <h3 class="text-xs font-bold text-green-800 uppercase tracking-widest">Account Protected</h3>
                    <p class="text-[11px] text-green-700/80">All other active sessions have been signed out for your safety.</p>
                </div>
            </div>

            <div class="space-y-4">
                <a href="/user/login" class="block w-full bg-blue-600 hover:bg-slate-500 text-white font-semibold py-4 rounded-xl transition-all shadow-lg shadow-slate-900/10 flex items-center justify-center gap-2">
                    Proceed to Login
                    <i data-lucide="arrow-right" class="w-4 h-4"></i>
                </a>
            </div>
        </div>

        <div class="bg-slate-50 py-4 border-t border-slate-100">
            <p class="text-[11px] text-slate-400">
                You will be automatically redirected in <span id="countdown" class="font-bold">10</span> seconds...
            </p>
        </div>
    </div>

    <script>
        lucide.createIcons();

        // Simple Countdown logic
        let timeLeft = 10;
        const countdownElem = document.getElementById('countdown');
        const timer = setInterval(() => {
            timeLeft--;
            countdownElem.innerText = timeLeft;
            if (timeLeft <= 0) {
                clearInterval(timer);
                window.location.href = "/user/login"; // Change this to your actual login route
            }
        }, 1000);
    </script>
</body>
</html>
