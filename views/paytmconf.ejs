<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UPay | Merchant Config</title>
    
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastify-js/1.6.1/toastify.js"></script>
    

    <style type="text/tailwindcss">
        body {
            background-color: #f8fafc;
            background-image: 
                radial-gradient(at 50% 0%, rgba(79, 70, 229, 0.05) 0px, transparent 50%);
            font-family: 'Inter', sans-serif;
        }
        .upay-font { font-family: 'Orbitron', sans-serif; }
        .fade-in { animation: fadeIn 0.4s ease-in-out; }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body class="flex items-center justify-center min-h-screen p-4 text-slate-900">

    <div class="w-full max-w-md bg-white rounded-3xl shadow-xl shadow-slate-200/60 border border-slate-100 overflow-hidden fade-in relative">
        
        <a href="/user/dashboard" class="absolute top-6 left-6 p-2 rounded-full hover:bg-slate-50 text-slate-400 hover:text-indigo-600 transition-colors border border-transparent hover:border-slate-100">
            <i data-lucide="arrow-left" class="w-5 h-5"></i>
        </a>

        <div class="h-2 bg-indigo-600"></div>
        <div class="p-8 sm:p-10">
            <div class="flex flex-col items-center mb-8 text-center">
                <div class="w-16 h-16 bg-indigo-50 rounded-2xl flex items-center justify-center mb-6 border border-indigo-100 shadow-sm">
                    <i data-lucide="settings-2" class="text-indigo-600 w-8 h-8"></i>
                </div>
                <h1 class="text-2xl font-bold tracking-tight text-slate-900 upay-font">GATEWAY CONFIG</h1>
                <p class="text-slate-500 text-sm mt-2">Enter your Paytm merchant credentials to generate scannable terminal.</p>
            </div>

            <div class="space-y-5 mb-8">
                <div class="space-y-2">
                    <label class="text-[11px] font-bold text-slate-400 uppercase tracking-widest upay-font ml-1">Paytm UPI ID</label>
                    <div class="relative">
                        <i data-lucide="at-sign" class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
                        <input type="text" id="upiId"
                        value="<%=paytm?paytm.UPI:''%>"
                        placeholder="merchant@paytm" 
                        value=""
                            class="w-full bg-slate-50/50 border border-slate-200 rounded-xl py-3.5 pl-11 pr-4 focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/5 outline-none transition-all font-mono text-sm">
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="text-[11px] font-bold text-slate-400 uppercase tracking-widest upay-font ml-1">Merchant ID (MID)</label>
                    <div class="relative">
                        <i data-lucide="hash" class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
                        <input type="text" 
                        value="<%=paytm?paytm.MID:''%>"
                        id="mid" placeholder="M-ID-XXXX-XXXX" 
                            class="w-full bg-slate-50/50 border border-slate-200 rounded-xl py-3.5 pl-11 pr-4 focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/5 outline-none transition-all font-mono text-sm">
                    </div>
                </div>
            </div>

            <button onclick="generateConfig()" id="verify-btn" 
                class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-4 rounded-xl transition-all shadow-lg shadow-indigo-200 flex items-center justify-center gap-2 upay-font text-sm active:scale-[0.98]">
                [ CONFIGURE & CHECK ]
            </button>
        </div>

        <div class="bg-slate-50 py-4 border-t border-slate-100 text-center">
            <p class="text-[11px] text-slate-400 uppercase tracking-widest upay-font">Security Verified Node</p>
        </div>
    </div>

    <div id="qrOverlay" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm hidden items-center justify-center p-6 z-50">
        <div class="bg-white rounded-3xl p-8 max-w-xs w-full text-center shadow-2xl border border-slate-100 fade-in">
            <h3 class="text-slate-900 font-bold text-lg mb-4 upay-font tracking-tight">TERMINAL READY</h3>
            <div class="bg-white p-4 rounded-2xl inline-block mb-4 border border-slate-100 shadow-inner">
                <img id="qr-code" src="" alt="QR Code" class="w-48 h-48">
            </div>
            <p id="qrInfo" class="text-slate-500 text-[10px] mb-6 font-mono bg-slate-50 p-2 rounded-lg truncate"></p>
            <button onclick="closePopup()" class="w-full py-3 bg-slate-900 text-white rounded-xl font-bold hover:bg-slate-800 transition shadow-md upay-font text-xs uppercase">
                Close Terminal
            </button>
        </div>
    </div>

    <script>
        lucide.createIcons();

        function tst(text, isError = false) {    
            Toastify({
                text,
                duration: 3000,
                gravity: "top",
                position: "center",
                style: { 
                    background: isError ? "#ef4444" : "#4f46e5",
                    borderRadius: "12px",
                    fontFamily: "'Orbitron', sans-serif",
                    fontSize: "11px"
                }
            }).showToast();
            if(isError && navigator.vibrate) navigator.vibrate(200);
        }

        async function generateConfig() {
            const upi = document.getElementById('upiId').value;
            const mid = document.getElementById('mid').value;

            if (!upi || !mid) return tst("ERROR: EMPTY FIELDS", true);

            const btn = document.getElementById('verify-btn');
            const originalContent = btn.innerHTML;
            btn.innerHTML = `<i data-lucide="loader-2" class="w-4 h-4 animate-spin"></i> GENERATING...`;
            lucide.createIcons();
            btn.disabled = true;

            try {
                const response = await fetch("/user/dashboard/paytm", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ MID: mid, UPI: upi })
                });
                
                const data = await response.json();

                if (data.status) {
                    // QR Generation
                    const upiData = `upi://pay?pa=${upi}&pn=Merchant&mc=${mid}&mode=02&purpose=00`;
                    document.getElementById('qr-code').src = `https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=${encodeURIComponent(upiData)}`;
                    document.getElementById('qrInfo').innerText = `UPI: ${upi}`;
                    
                    // Show Overlay
                    document.getElementById('qrOverlay').classList.remove('hidden');
                    document.getElementById('qrOverlay').classList.add('flex');
                    
                    tst(data.message || "GATEWAY INITIALIZED");
                } else {
                    tst(data.message || "INITIALIZATION FAILED", true);
                }
            } catch (err) {
                tst("NETWORK ERROR", true);
            } finally {
                btn.innerHTML = originalContent;
                btn.disabled = false;
                lucide.createIcons();
            }
        }

        function closePopup() {
            document.getElementById('qrOverlay').classList.add('hidden');
            document.getElementById('qrOverlay').classList.remove('flex');
        }
    </script>
</body>
</html>
