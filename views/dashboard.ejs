<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>UPay Pro | Enterprise Fintech Terminal</title>
    
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastify-js/1.6.1/toastify.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500;700&display=swap');
        
        :root {
            --primary: #4f46e5;
            --surface: #ffffff;
            --background: #f8fafc;
            --font-main: 'Plus Jakarta Sans', sans-serif;
        }

        body { 
            font-family: var(--font-main); 
            background-color: var(--background);
            color: #0f172a;
            -webkit-tap-highlight-color: transparent;
        }

        /* Glassmorphism & Custom Shadows */
        .glass-header {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }

        .u-card { 
            background: white; 
            border: 1px solid #f1f5f9; 
            border-radius: 1.5rem;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .u-input { 
            width: 100%; padding: 1rem 1.25rem; border-radius: 1rem; 
            border: 2px solid #f1f5f9; background: #ffffff; 
            font-weight: 600; transition: all 0.2s;
        }
        .u-input:focus { border-color: var(--primary); outline: none; background: #fff; }

        /* Animation Classes */
        .tab-pane { display: none; opacity: 0; transform: translateY(10px); }
        .tab-pane.active { display: block; opacity: 1; transform: translateY(0); transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
        
        .refresh-spin { animation: spin 0.8s cubic-bezier(0.4, 0, 0.2, 1); }
        @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

        /* Loading Shimmer */
        .shimmer {
            background: linear-gradient(90deg, #f0f2f5 25%, #f8fafc 50%, #f0f2f5 75%);
            background-size: 200% 100%;
            animation: shimmer 1.5s infinite;
        }
        @keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

        /* Scrollbar Hide */
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

        .btn-bounce:active { transform: scale(0.95); }
    </style>
</head>
<body class="overflow-hidden select-none">

    <div class="flex h-screen w-full">

        <aside class="hidden lg:flex w-80 flex-col bg-white border-r border-slate-100 p-6">
            <div class="flex items-center gap-3 px-4 mb-12">
                <div class="bg-indigo-600 p-2.5 rounded-2xl text-white shadow-lg shadow-indigo-200">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                </div>
                <h1 class="text-2xl font-extrabold tracking-tight">UPay<span class="text-indigo-600">.</span></h1>
            </div>

            <nav class="flex-1 space-y-2">
                <button onclick="Terminal.nav('overview')" data-nav="overview" class="nav-link active w-full flex items-center gap-4 px-5 py-4 rounded-2xl bg-indigo-50 text-indigo-600 font-bold transition-all">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
                    Overview
                </button>
                <button onclick="Terminal.nav('history')" data-nav="history" class="nav-link w-full flex items-center gap-4 px-5 py-4 rounded-2xl text-slate-400 hover:bg-slate-50 font-bold transition-all">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
                    Ledger
                </button>
                <button onclick="Terminal.nav('developer')" data-nav="developer" class="nav-link w-full flex items-center gap-4 px-5 py-4 rounded-2xl text-slate-400 hover:bg-slate-50 font-bold transition-all">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
                    Integrations
                </button>
                <button onclick="Terminal.nav('profile')" data-nav="profile" class="nav-link w-full flex items-center gap-4 px-5 py-4 rounded-2xl text-slate-400 hover:bg-slate-50 font-bold transition-all">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                    Settings
                </button>
            </nav>

            <div class="mt-auto bg-slate-900 rounded-3xl p-6 text-white relative overflow-hidden">
                <div class="relative z-10">
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Support Tier</p>
                    <h4 class="text-lg font-bold mt-1">Priority Gold</h4>
                    <button class="mt-4 text-xs font-bold bg-indigo-600 px-4 py-2 rounded-lg">Get Help</button>
                </div>
                <svg class="absolute -right-4 -bottom-4 w-24 h-24 text-white/5" fill="currentColor" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
        </aside>

        <main id="view-scroller" class="flex-1 overflow-y-auto no-scrollbar relative bg-slate-50 pb-32 lg:pb-12">
            
            <header class="sticky top-0 z-[60] glass-header px-6 lg:px-12 py-6 flex items-center justify-between border-b border-slate-100">
                <div class="flex items-center gap-4">
                    <div class="lg:hidden bg-indigo-600 p-1.5 rounded-lg text-white">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    </div>
                    <div>
                        <h2 id="view-title" class="text-xl font-extrabold text-slate-900 tracking-tight">Dashboard</h2>
                        <div class="flex items-center gap-2">
                            <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Live Node: HK-442</p>
                        </div>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <button onclick="Terminal.simulateSync(this)" class="p-2.5 rounded-xl bg-white border border-slate-200 text-slate-400 btn-bounce shadow-sm">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                    </button>
                    <div class="relative group">
                        <img src="<%=(user.pic)?user.pic:`https://ui-avatars.com/api/?name=${user.firstname}+${user.lastname}&background=4f46e5&color=fff&bold=true`%>" class="w-10 h-10 rounded-2xl ring-4 ring-white shadow-md">
                        <div class="absolute -bottom-1 -right-1 w-4 h-4 bg-emerald-500 border-2 border-white rounded-full"></div>
                    </div>
                </div>
            </header>

            <div class="max-w-6xl mx-auto p-5 lg:p-12">

                <section id="view-overview" class="tab-pane active space-y-8">
                    
                    <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
                        <div class="md:col-span-7 bg-indigo-600 rounded-[2rem] p-8 text-white shadow-2xl shadow-indigo-200 relative overflow-hidden group">
                            <div class="absolute top-0 right-0 p-8 opacity-20 group-hover:scale-110 transition-transform">
                                <svg class="w-32 h-32" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>
                            </div>
                            
                            <div class="relative z-10">
                                <div class="flex items-center justify-between">
                                    <span class="text-xs font-bold uppercase tracking-widest opacity-80">Available Liquidity</span>
                                    <button onclick="Terminal.refreshBalance(this)" class="p-2 hover:bg-white/10 rounded-lg transition-colors">
                                        <svg id="balance-refresh-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                                    </button>
                                </div>
                                <h3 id="stat-balance" class="text-5xl lg:text-6xl font-black mt-4 tabular-nums">&#8377;<%=user.wallet%></h3>
                                <div class="flex items-center gap-2 mt-2 text-emerald-300 font-bold text-sm">
                                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M5.293 7.707a1 1 0 010-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 01-1.414 1.414L11 5.414V17a1 1 0 11-2 0V5.414L6.707 7.707a1 1 0 01-1.414 0z"/></svg>
                                    +12.5% vs last week
                                </div>
                                
                                <div class="flex gap-3 mt-10">
                                    <button onclick="Terminal.simulateSettlement()" class="flex-1 bg-white text-indigo-600 py-4 rounded-2xl font-extrabold text-sm btn-bounce shadow-lg">Request Settlement</button>
                                    <button class="px-5 bg-indigo-500 text-white rounded-2xl btn-bounce" onclick="openpop()">
                                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="md:col-span-5 space-y-6">
                          <%if (user.bank.bank){%>  <div class="u-card p-6 flex items-center justify-between border-slate-200">
                                <div>
                                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Active Settlement Bank</p>
                                    <h4 class="text-lg font-extrabold text-slate-800 mt-1"><%=user.bank.bank%></h4>
                                    <p class="font-mono text-xs text-slate-500 font-bold tracking-tighter">xxxxxxxx<%=user.bank.account.slice(-4)%></p>
                                </div>
                                <div class="bg-slate-50 p-3 rounded-2xl">
                                  <img src="<%=user.bank.logo%>" alt="<%=user.bank.bank%>"/>
                                </div>
                            </div>
                            <% } %>
                            
                            <div class="grid grid-cols-2 gap-4">
                                <div class="u-card p-6 border-slate-200">
                                    <p class="text-[10px] font-bold text-slate-400 uppercase">Success Rate</p>
                                    <p class="text-2xl font-black text-slate-800 mt-1">99.2%</p>
                                </div>
                                <div class="u-card p-6 border-slate-200">
                                    <p class="text-[10px] font-bold text-slate-400 uppercase">Daily Limit</p>
                                    <p class="text-2xl font-black text-slate-800 mt-1">$50k</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="u-card p-8">
                        <div class="flex items-center justify-between mb-10">
                            <div>
                                <h4 class="text-xl font-black text-slate-800">Growth Metrics</h4>
                                <p class="text-xs font-bold text-slate-400">Real-time processing volume (7 Days)</p>
                            </div>
                            <select class="bg-slate-50 border-none text-xs font-bold text-slate-500 rounded-lg px-3 py-2 outline-none">
                                <option>Weekly View</option>
                                <option>Monthly View</option>
                            </select>
                        </div>
                        <div class="h-[300px] w-full relative">
                            <canvas id="mainChart"></canvas>
                        </div>
                    </div>
                </section>

                <section id="view-history" class="tab-pane">
                    <div class="u-card p-6 lg:p-10">
                        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-10">
                            <div>
                                <h3 class="text-2xl font-black text-slate-900">Transaction Ledger</h3>
                                <p class="text-xs font-bold text-slate-400 mt-1">Audit-ready logs for fiscal year 2025</p>
                            </div>
                            <div class="flex gap-2">
                                <div class="relative flex-1 md:w-64">
                                    <input type="text" placeholder="Search ID..." class="u-input !py-2.5 !pl-10 text-sm">
                                    <svg class="w-4 h-4 absolute left-3.5 top-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                                </div>
                                <button onclick="Terminal.refreshHistory(this)" class="p-2.5 bg-slate-900 text-white rounded-xl btn-bounce">
                                    <svg id="history-refresh-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                                </button>
                            </div>
                        </div>

                        <div id="tx-container" class="space-y-3 min-h-[400px]">
                            </div>

                        <div class="mt-8 flex justify-center">
                            <button class="text-xs font-bold text-indigo-600 hover:bg-indigo-50 px-6 py-3 rounded-xl transition-all">Load Archive Data</button>
                        </div>
                    </div>
                </section>

                <section id="view-developer" class="tab-pane max-w-3xl mx-auto space-y-6">
                    <div class="bg-slate-900 rounded-[2rem] p-8 text-white shadow-xl">
                        <div class="flex items-center gap-3 mb-8">
                            <div class="p-2 bg-indigo-500 rounded-lg">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path></svg>
                            </div>
                            <h3 class="text-xl font-bold">API Authentication</h3>
                        </div>
                        
                        <div class="space-y-4">
                            <div>
                                <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest ml-1">Live Secret Key</label>
                                <div class="mt-1.5 flex items-center justify-between bg-white/5 border border-white/10 p-4 rounded-2xl font-mono text-indigo-300 text-sm">
                                    <span class="text-[10px]"><%=user.api%></span>
                                    <button onclick="Terminal.copy('<%=user.api%>')" class="text-indigo-400 hover:text-white font-bold px-3">Copy</button>
                                </div>
                            </div>
                            <div>
                                <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest ml-1">Merchant ID</label>
                                <div class="mt-1.5 flex items-center justify-between bg-white/5 border border-white/10 p-4 rounded-2xl font-mono text-slate-400 text-sm">
                                    <span><%=user.MID%></span>
                                    <button onclick="Terminal.copy('<%=user.MID%>')" class="hover:text-white">Copy</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="u-card p-8">
                        <h3 class="text-xl font-black mb-8">Webhook Configuration</h3>
                        <div class="space-y-5">
                            <div>
                                <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">Success Callback URL</label>
                                <input type="text"
                    id="callback"
                    value="<%=user.callback%>"
                    placeholder="https://api.yourdomain.com/v1/success" class="u-input mt-1">
                            </div>
                            <div>
                                <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">Redirect URL</label>
                                <input type="text"
                    id="redirect" 
                    value="<%=user.redirect%>"
                    placeholder="https://yourdomain.com/thanks" class="u-input mt-1">
                            </div>
                            <div class="flex items-center gap-3 p-4 bg-amber-50 rounded-2xl border border-amber-100">
                                <svg class="w-6 h-6 text-amber-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                                <p class="text-[11px] font-bold text-amber-700 leading-tight">Endpoints must support HTTPS and return a 200 OK status within 3000ms.</p>
                            </div>
                            <button onclick="Terminal.saveSettings(this)" class="w-full py-4 bg-indigo-600 text-white rounded-2xl font-black shadow-lg shadow-indigo-100 btn-bounce mt-4">Deploy Changes</button>
                        </div>
                    </div>
                </section>

                <section id="view-profile" class="tab-pane max-w-3xl mx-auto">
                    <div class="flex bg-slate-200/50 p-1.5 rounded-2xl w-fit mb-8">
                        <button onclick="Terminal.subProfile('identity')" id="sub-nav-identity" class="sub-trigger px-8 py-2.5 rounded-xl font-bold text-[11px] uppercase bg-white shadow-sm text-indigo-600 transition-all">Business Info</button>
                        <button onclick="Terminal.subProfile('banking')" id="sub-nav-banking" class="sub-trigger px-8 py-2.5 rounded-xl font-bold text-[11px] uppercase text-slate-500 transition-all">Settlement Info</button>
                    </div>

                    <div id="sub-view-identity" class="sub-pane active u-card p-8 lg:p-12">
                        <div class="flex items-center gap-6 mb-10">
                            <div class="relative">
                                <img src="<%=(user.pic)?user.pic:`https://ui-avatars.com/api/?name=${user.firstname}+${user.lastname}&background=4f46e5&color=fff&bold=true`%>" class="w-25 h-20 rounded-[100%]">
                                <button class="absolute -bottom-1 -right-1 bg-white p-2 rounded-full shadow-md border border-slate-100">
                                    <svg class="w-4 h-4 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path></svg>
                                </button>
                            </div>
                            <div>
                                <h3 class="text-2xl font-black text-slate-900">Merchant Identity</h3>
                                <p class="text-sm font-bold text-slate-400">Manage your public and tax profile</p>
                            </div>
                        </div>

                        <form onsubmit="Terminal.saveProfile(event)" class="space-y-6">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">Legal First Name</label>
                                    <input name="firstname" type="text" value="<%=user.firstname%>" class="u-input mt-1.5">
                                </div>
                                <div>
                                    <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">Legal Last Name</label>
                                    <input name="lastname" type="text" value="<%=user.lastname%>" class="u-input mt-1.5">
                                </div>
                            </div>
                            <div>
                                <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">Business Email</label>
                                <input type="email" value="<%=user.email%>"
                              class="u-input mt-1.5" readonly="">
                            </div>
                    <div>
                                <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">Business Name</label>
                                <input type="text" 
                                name="company"value="<%=user.company || "UPay PVT LTD"%>" class="u-input mt-1.5" >
                            </div>
                            <div>
                                <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">Phone Number</label>
                                <input type="tel" value="+91 <%=user.mobile || "0000000000"%>" 
                                name="mobile"class="u-input mt-1.5">
                            </div>
                            <button type="submit" class="w-full py-4 bg-slate-900 text-white rounded-2xl font-black btn-bounce">Update Profile</button>
                        </form>
                    </div>

                    <div id="sub-view-banking" class="sub-pane u-card p-8 lg:p-12 hidden">
                        <h3 class="text-2xl font-black mb-2">Banking Rails</h3>
                        <p class="text-sm font-bold text-slate-400 mb-10">Verification required for changes over $10,000</p>
                        
                        <form onsubmit="Terminal.saveBank(event)" class="space-y-6">
                            <div>
                              <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">Bank Name</label>
                            <select
                            onchange=""
                            name="bank"
                                value="<%if (user.bank.bank){%><%=user.bank.bank%><% } %>"
                   class="u-input mt-1.5"><%list.forEach((val)=>{%> 
                   <option value="<%=val.name%>" <%=val.name==user.bank.bank?"selected":""%>><%=val.name%></option>
                   <%})%>
                   
                   </select>
                                <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">Account Holder</label>
                                <input type="text"
                          name="holder"      value="<%if (user.bank.bank){%><%=user.bank.holder%><% } %>"
                    placeholder="UPay Enterprise LLC" class="u-input mt-1.5">
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">Account Number</label>
                                    <input type="number"
                    value="<%if (user.bank.bank){%><%=user.bank.account%><% } %>"    
                    name="account" placeholder="•••• •••• 9901" class="u-input mt-1.5">
                                </div>
                                <div>
                                    <label class="text-[10px] font-bold text-slate-400 uppercase ml-1">IFSC</label>
                                    <input type="text"
                    value="<%if (user.bank.bank){%><%=user.bank.ifsc%><% } %>"   name="ifsc"          placeholder="JP000982" class="u-input mt-1.5 uppercase">
                                </div>
                            </div>
                            <div class="p-6 bg-slate-50 rounded-2xl border border-dashed border-slate-200">
                                <p class="text-[11px] text-slate-500 font-medium text-center">By saving, you authorize UPay Pro to initiate ACH credit entries to the bank account indicated above.</p>
                            </div>
                            <button type="submit" class="w-full py-4 bg-indigo-600 text-white rounded-2xl font-black shadow-lg shadow-indigo-100 btn-bounce">Secure Save Bank</button>
                        </form>
                    </div>
                </section>

            </div>
        </main>

        <nav class="lg:hidden fixed bottom-0 left-0 right-0 bg-white/95 backdrop-blur-xl border-t border-slate-100 h-24 flex justify-around items-center px-6 z-[100] pb-4">
            <button onclick="Terminal.nav('overview')" data-mob="overview" class="mob-link text-indigo-600 flex flex-col items-center gap-1.5">
                <div class="p-2.5 rounded-2xl bg-indigo-50">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
                </div>
                <span class="text-[10px] font-extrabold uppercase tracking-tight">Home</span>
            </button>
            <button onclick="Terminal.nav('history')" data-mob="history" class="mob-link text-slate-300 flex flex-col items-center gap-1.5">
                <div class="p-2.5 rounded-2xl">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
                </div>
                <span class="text-[10px] font-extrabold uppercase tracking-tight">Ledger</span>
            </button>
            <button onclick="Terminal.nav('developer')" data-mob="developer" class="mob-link text-slate-300 flex flex-col items-center gap-1.5">
                <div class="p-2.5 rounded-2xl">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
                </div>
                <span class="text-[10px] font-extrabold uppercase tracking-tight">API</span>
            </button>
            <button onclick="Terminal.nav('profile')" data-mob="profile" class="mob-link text-slate-300 flex flex-col items-center gap-1.5">
                <div class="p-2.5 rounded-2xl">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                </div>
                <span class="text-[10px] font-extrabold uppercase tracking-tight">Setup</span>
            </button>
        </nav>
    </div>
 <script src="/js/popup.js"></script>
    <script>
        /**
         * UPay Pro Core Terminal Engine
         * Handles View Routing, Real-time Simulations, and UI Orchestration
         */
        const Terminal = {
            state: {
                balance: parseFloat(<%=user.wallet%>),
                isRefreshing: false,
                chart: null,
                transactions: [

                ]
            },

            init() {
                this.renderTransactions();
                this.initChart();
                this.setupInterceptors();
            },

            nav(viewId) {
                // UI Management
                document.getElementById('view-scroller').scrollTo({ top: 0, behavior: 'smooth' });
                
                document.querySelectorAll('.tab-pane').forEach(el => el.classList.remove('active'));
                const target = document.getElementById(`view-active-${viewId}`) || document.getElementById(`view-${viewId}`);
                target.classList.add('active');

                // Update Title
                const titles = { overview: 'Dashboard', history: 'Transaction Ledger', developer: 'Integrations', profile: 'Settings' };
                document.getElementById('view-title').innerText = titles[viewId];

                // Update Desktop Nav
                document.querySelectorAll('.nav-link').forEach(el => {
                    el.classList.remove('bg-indigo-50', 'text-indigo-600', 'active');
                    el.classList.add('text-slate-400', 'hover:bg-slate-50');
                });
                const activeNav = document.querySelector(`[data-nav="${viewId}"]`);
                activeNav.classList.add('bg-indigo-50', 'text-indigo-600', 'active');
                activeNav.classList.remove('text-slate-400', 'hover:bg-slate-50');

                // Update Mobile Nav
                document.querySelectorAll('.mob-link').forEach(el => {
                    el.classList.replace('text-indigo-600', 'text-slate-300');
                    el.querySelector('div').classList.remove('bg-indigo-50');
                });
                const activeMob = document.querySelector(`[data-mob="${viewId}"]`);
                activeMob.classList.replace('text-slate-300', 'text-indigo-600');
                activeMob.querySelector('div').classList.add('bg-indigo-50');

                if(viewId === 'overview') this.initChart();
            },

            subProfile(subId) {
                document.querySelectorAll('.sub-pane').forEach(el => el.classList.add('hidden'));
                document.getElementById(`sub-view-${subId}`).classList.remove('hidden');

                document.querySelectorAll('.sub-trigger').forEach(el => {
                    el.classList.remove('bg-white', 'shadow-sm', 'text-indigo-600');
                    el.classList.add('text-slate-500');
                });
                document.getElementById(`sub-nav-${subId}`).classList.add('bg-white', 'shadow-sm', 'text-indigo-600');
            },

            /**
             * Simulation: Balance Refresh Logic
             */
            async refreshBalance(btn) {
                if(this.state.isRefreshing) return;
                this.state.isRefreshing = true;

                const icon = document.getElementById('balance-refresh-icon');
                icon.classList.add('refresh-spin');

                // Simulate API Latency
                await fetch("/user/dashboard/balance").then(e=>{return e.json()}).then(e=> {
                    
                    this.state.balance=e.wallet;
                    
                    gsap.to(this.state, {
                        balance: this.state.balance,
                        duration: 1,
                        onUpdate: () => {
                            document.getElementById('stat-balance').innerText = `₹${this.state.balance.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
                        }
                    });

                    icon.classList.remove('refresh-spin');
                    this.state.isRefreshing = false;
                    this.notify('Balance Sync Successful');
                });
            },

            /**
             * Simulation: History Refresh Logic
             */
           async refreshHistory(btn) {
                const icon = document.getElementById('history-refresh-icon');
                const container = document.getElementById('tx-container');
                
                icon.classList.add('refresh-spin');
                container.style.opacity = '0.5';
                await fetch("/user/dashboard/transections").then(e=>{
                  return e.json()
                }).then(e=>{
                  this.state.transactions=e
                    this.renderTransactions();
                    
                    icon.classList.remove('refresh-spin');
                    container.style.opacity = '1';
                    this.notify('Ledger Updated');
                },);
            },

            simulateSettlement() {
                this.notify('Settlement Request Sent to Bank');
                setTimeout(() => {
                    this.notify('J.P. Morgan Processing... (ETA 2h)', 'info');
                }, 1500);
            },

            async saveProfile(e) {
                e.preventDefault();
                const formdata=new FormData(e.target)
                const data=Object.fromEntries(formdata.entries())
                fetch('/user/dashboard/profile', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                }).then(e=>{return e.json()}).then(e=>{
                  if(e.status){
                    this.notify(e.message);
                    return 0
                  }
                  this.notify(e.message);
                  return -1
                });
            },

            saveBank(e) {
                e.preventDefault();
                const formdata=new FormData(e.target)
                const data=Object.fromEntries(formdata.entries())
                fetch('/user/dashboard/bank', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                }).then(e=>{return e.json()}).then(e=>{
                  if(e.status){
                    this.notify(e.message);
                    return 0
                  }
                  this.notify(e.message);
                  return -1
                });
                
            },

            saveSettings(btn) {
                btn.innerText = "Deploying...";
                btn.disabled = true;
                let callback=document.getElementById("callback").value
                let redirect=document.getElementById("redirect").value
                let data={callback,redirect}
                 fetch('/user/dashboard/callback', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                }).then(e=>{return e.json()}).then(e=>{
                  if(e.status){
                    this.notify(e.message);
                    btn.disabled=false;
                  btn.innerText="Deploy"
                    return 0
                  }
                  this.notify(e.message);
                  btn.disabled=false;
                  btn.innerText="Deploy"
                  return -1
                });
            },

           async renderTransactions() {
              
             const resp=await fetch("/user/dashboard/transections")
             const re=await resp.json()
             this.state.transactions=re
              
              
              
              
              
              
                const container = document.getElementById('tx-container');
                container.innerHTML = this.state.transactions.map(tx => `
                    <div class="group flex items-center justify-between p-4 bg-white border border-slate-100 rounded-2xl hover:border-indigo-100 transition-all cursor-pointer">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-xl flex items-center justify-center ${tx.amount > 0 ? 'bg-emerald-50 text-emerald-600' : 'bg-rose-50 text-rose-600'}">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="${tx.amount > 0 ? 'M7 11l5-5m0 0l5 5m-5-5v12' : 'M17 13l-5 5m0 0l-5-5m5-5v12'}"></path></svg>
                            </div>
                            <div>
                         <p class="text-[14px] font-bold text-indigo-400 uppercase tracking-tighter">${tx.mode||"Default"}</p>  
                                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter">${tx.utr}</p>
                            </div>
                        </div>
                        <div class="text-right">
                            <p class="font-black text-sm ${tx.amount > 0 ? 'text-emerald-600' : 'text-slate-900'}">
                                ${tx.amount > 0 ? '+' : ''}${tx.amount.toLocaleString(undefined, {minimumFractionDigits: 2})}
                            </p>
                            
                        </div>
                    </div>
                `).join('');
            },

            initChart() {
                const ctx = document.getElementById('mainChart').getContext('2d');
                if(this.state.chart) this.state.chart.destroy();
                
                const gradient = ctx.createLinearGradient(0, 0, 0, 300);
                gradient.addColorStop(0, 'rgba(79, 70, 229, 0.1)');
                gradient.addColorStop(1, 'rgba(79, 70, 229, 0)');

                this.state.chart = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                        datasets: [{
                            label: 'Volume',
                            data: [4200, 7800, 5600, 11200, 9800, 15400, 14250],
                            borderColor: '#4f46e5',
                            borderWidth: 4,
                            pointBackgroundColor: '#fff',
                            pointBorderColor: '#4f46e5',
                            pointBorderWidth: 2,
                            pointRadius: 4,
                            tension: 0.45,
                            fill: true,
                            backgroundColor: gradient
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            y: { display: false },
                            x: { grid: { display: false }, border: { display: false }, ticks: { font: { weight: 'bold', size: 10 } } }
                        }
                    }
                });
            },

            notify(text, type = 'success') {
                Toastify({
                    text: text,
                    duration: 3000,
                    gravity: "top",
                    position: "center",
                    style: {
                        background: type === 'success' ? "#0f172a" : "#f59e0b",
                        borderRadius: "12px",
                        fontSize: "12px",
                        fontWeight: "800",
                        boxShadow: "0 10px 15px -3px rgba(0,0,0,0.1)"
                    }
                }).showToast();
            },

            copy(text) {
                navigator.clipboard.writeText(text);
                this.notify('Copied to Clipboard');
            },

            simulateSync(btn) {
                this.notify('Syncing with Global Nodes...');
                btn.classList.add('refresh-spin');
                setTimeout(() => btn.classList.remove('refresh-spin'), 1000);
            },

            setupInterceptors() {
                // Prevent elastic scrolling on iOS
                document.body.addEventListener('touchmove', (e) => {
                    if (e.target.closest('#view-scroller')) return;
                    e.preventDefault();
                }, { passive: false });
            }
        };
function openpop(){
  const DepositPopup = new UPayDeposit();
DepositPopup.open()
}
        // Boot
        window.onload = () => Terminal.init();
        
    </script>
   
    
</body>
</html>
