<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UPay | System Error</title>
    
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    
    <script src="https://unpkg.com/lucide@latest"></script>

    <style type="text/tailwindcss">
        @theme {
            --color-upay-slate: #64748b;
        }

        body {
            background-color: #ffffff;
            background-image: 
                radial-gradient(at 50% 100%, rgba(203, 213, 225, 0.1) 0px, transparent 50%);
        }

        .float-animation {
            animation: float 4s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
    </style>
</head>
<body class="flex items-center justify-center min-h-screen p-6 font-sans text-slate-900">

    <div class="w-full max-w-lg text-center">
        
        <div class="relative inline-block mb-10">
            <div class="w-32 h-32 bg-slate-50 rounded-full flex items-center justify-center border border-slate-100 shadow-sm float-animation">
                <i data-lucide="alert-triangle" class="text-slate-400 w-14 h-14"></i>
            </div>
            <div class="absolute -bottom-2 -right-2 w-12 h-12 bg-white rounded-xl shadow-lg border border-slate-100 flex items-center justify-center">
                <i data-lucide="settings" class="text-blue-500 w-6 h-6 animate-spin-slow" style="animation: spin 8s linear infinite;"></i>
            </div>
        </div>

        <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 mb-4">Something went wrong</h1>
        <p class="text-slate-500 text-base max-w-sm mx-auto mb-10 leading-relaxed">
            We're having trouble processing your request right now. This is likely a temporary system hiccup.
        </p>

        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-slate-100 rounded-full border border-slate-200 mb-12">
            <span class="w-2 h-2 bg-slate-400 rounded-full"></span>
            <code class="text-[10px] font-mono text-slate-500 uppercase tracking-widest">Error Code: 500_INTERNAL_SERVER</code>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-md mx-auto">
            <button onclick="window.location.reload()" class="flex items-center justify-center gap-2 bg-blue-600 hover:bg-slate-800 text-white font-semibold py-4 rounded-2xl transition-all active:scale-95 shadow-xl shadow-slate-900/10">
                <i data-lucide="refresh-cw" class="w-4 h-4"></i>
                Try Again
            </button>
            
            <a href="/dashboard" class="flex items-center justify-center gap-2 bg-white hover:bg-slate-50 text-slate-700 font-semibold py-4 rounded-2xl transition-all border border-slate-200 active:scale-95">
                <i data-lucide="home" class="w-4 h-4"></i>
                Go Home
            </a>
        </div>

        <p class="mt-12 text-sm text-slate-400">
            If this keeps happening, contact our <a href="#" class="text-blue-600 font-medium hover:underline">Support Team</a>.
        </p>
    </div>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>
